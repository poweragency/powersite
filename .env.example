# ─────────────────────────────────────────────────────────────
# POWER AGENCY — Landing SaaS / env vars (stateless edition)
# Copia in .env.local e popola con i valori reali.
# ─────────────────────────────────────────────────────────────

# ── Claude API (Anthropic) ────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_COPY=claude-sonnet-4-6
ANTHROPIC_MODEL_LAYOUT=claude-opus-4-7

# ── Vercel Blob (storage effimero per immagini in transito) ──
# Auto-popolato da Vercel su deploy se aggiungi l'integrazione Blob.
# Per dev locale: vercel link → vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# IDs Price Stripe (creati una volta, riusati per ogni ordine).
# MODELLO CANONE MENSILE: tier e addon mensili devono essere Price RICORRENTI
# mensili; il logo è l'unico Price ONE-TIME. Importi (vedi lib/catalog.ts SSOT):
#   STANDARD 29,97/mese · PREMIUM 49,97/mese · BUSINESS(Signature) 69,97/mese
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_BUSINESS=
#   SEO/GEO/GAIO 1,50/mese · ANALYTICS 2/mese · CHATBOT 5/mese
#   EMAIL_FUNNEL 3/mese · BOOKING 5/mese · CONTACT_FORM_INTEGRATION 4/mese
STRIPE_PRICE_ADDON_SEO=
STRIPE_PRICE_ADDON_GEO=
STRIPE_PRICE_ADDON_GAIO=
STRIPE_PRICE_ADDON_ANALYTICS=
STRIPE_PRICE_ADDON_CHATBOT=
STRIPE_PRICE_ADDON_EMAIL_FUNNEL=
STRIPE_PRICE_ADDON_BOOKING=
STRIPE_PRICE_ADDON_CONTACT_FORM_INTEGRATION=
#   LOGO_DESIGN: Price ONE-TIME 147€ (pagamento una-tantum)
STRIPE_PRICE_ADDON_LOGO_DESIGN=
# NB: "Gestionale su misura" (ex CONTACT_FORM_BESPOKE) è ora "su preventivo":
# nessun addebito, nessun Price Stripe. La var sotto NON è più usata.
STRIPE_PRICE_ADDON_CONTACT_FORM_BESPOKE=

# DEPRECATO: il canone mensile del tier include già dominio + hosting +
# mantenimento. Non c'è più una subscription "Manutenzione" separata.
STRIPE_PRICE_MAINTENANCE=

# ── GitHub (creazione repo cliente) ───────────────────────────
# Token fine-grained PAT con permissions:
#   - Administration: Read and write (per creare nuove repo)
#   - Contents: Read and write (per pushare i file)
#   - Metadata: Read-only (default)
# Genera su: https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=

# Mode di creazione:
#   - "user" (default): repo nel personal account del proprietario del PAT.
#     Vantaggio: Vercel Hobby deploya repo private personali GRATIS.
#     GITHUB_OWNER va lasciato VUOTO (derivato automaticamente dal token).
#   - "org": repo in una GitHub Organization.
#     Richiede Vercel Pro ($20/mese) per deployare repo private d'org.
#     Setta GITHUB_OWNER al nome dell'org.
GITHUB_OWNER_TYPE=user
GITHUB_OWNER=

# ── Vercel (deploy repo cliente) ──────────────────────────────
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_DOMAIN_BASE=poweragency.it

# ── CRM (Supabase "power-hub") ────────────────────────────────
# Project: rageiputoupzrdqthgvw (org POWER AGENCY, eu-central-1)
# La pipeline scrive il lead finale (con preview_url) nella tabella
# public.powersites_leads. L'utente apre Supabase Studio per vederli
# e contattare i clienti via WhatsApp/telefono.
# SERVICE_ROLE_KEY è secret backend-only — bypassa RLS, mai esporlo client-side.
POWERHUB_SUPABASE_URL=https://rageiputoupzrdqthgvw.supabase.co
POWERHUB_SUPABASE_SERVICE_ROLE_KEY=
# Publishable/anon key (sb_publishable_...). Letta dal SaaS e iniettata come
# NEXT_PUBLIC_POWERHUB_ANON_KEY nei project Vercel cliente per il form contatti.
# Si trova in Supabase Dashboard > Settings > API keys > Publishable.
POWERHUB_ANON_KEY=

# ── Video AI (tier Business) ──────────────────────────────────
HEYGEN_API_KEY=

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3002

# ── Cron auth ─────────────────────────────────────────────────
# Stringa random (~32 char). Vercel passa `Authorization: Bearer $CRON_SECRET`
# al cron `/api/cron/cleanup-orphans`. Genera con:
#   openssl rand -hex 32
CRON_SECRET=

# ── Pipeline orchestrate ──────────────────────────────────────
# Quando true, /api/orders salta Stripe e triggera la pipeline direttamente
# via fetch fire-and-forget a /api/orchestrate. L'utente viene reindirizzato
# a /grazie senza pagamento. Utile in fase di test / pre-launch.
# Quando false (default), checkout Stripe come da flusso produzione.
BYPASS_STRIPE=true

# Secret per autenticare /api/orders -> /api/orchestrate.
# Se vuoto, usa CRON_SECRET come fallback. Genera con `openssl rand -hex 32`.
ORCHESTRATE_SECRET=
